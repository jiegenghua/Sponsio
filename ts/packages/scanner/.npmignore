# What ships to npm is dictated by the ``files`` field in
# package.json (whitelist) — this file is the deny-list backstop in
# case the whitelist is loosened by accident, and it documents
# *intent* for anyone reading the repo.

# Source / build inputs
src/
tsconfig.json
tsconfig.tsbuildinfo

# Tests + fixtures
tests/
vitest.config.*
*.test.ts

# Local dev artifacts
node_modules/
coverage/
.vscode/
.idea/
.DS_Store

# Examples + docs that live elsewhere
*.log
*.tgz

# Lockfile is for our own CI; the published package shouldn't carry
# it (npm will resolve from the consumer's lockfile).
package-lock.json
