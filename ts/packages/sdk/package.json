{
  "name": "@sponsio/sdk",
  "version": "0.1.0",
  "description": "Runtime contract enforcement for LLM agents — native TypeScript",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SponsioLabs/Sponsio.git",
    "directory": "ts/packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/SponsioLabs/Sponsio/issues"
  },
  "homepage": "https://github.com/SponsioLabs/Sponsio#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./claude-agent": {
      "types": "./dist/integrations/claude-agent.d.ts",
      "default": "./dist/integrations/claude-agent.js"
    },
    "./vercel-ai": {
      "types": "./dist/integrations/vercel-ai.d.ts",
      "default": "./dist/integrations/vercel-ai.js"
    },
    "./openai": {
      "types": "./dist/integrations/openai.d.ts",
      "default": "./dist/integrations/openai.js"
    },
    "./openai-agents": {
      "types": "./dist/integrations/openai-agents.d.ts",
      "default": "./dist/integrations/openai-agents.js"
    },
    "./google-adk": {
      "types": "./dist/integrations/google-adk.d.ts",
      "default": "./dist/integrations/google-adk.js"
    },
    "./langchain": {
      "types": "./dist/integrations/langchain.d.ts",
      "default": "./dist/integrations/langchain.js"
    }
  },
  "bin": {
    "sponsio": "bin/sponsio.cjs"
  },
  "files": [
    "dist/",
    "!dist/__tests__/**",
    "!dist/cli/__tests__/**",
    "bin/",
    "contracts/",
    "prompts/",
    "skills/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cli.json && node -e \"require('fs').writeFileSync('dist/cli/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "test": "node --test dist/__tests__/*.test.js",
    "test:cli": "node --test dist/cli/__tests__/*.test.js",
    "test:src": "npx tsx src/__tests__/core.test.ts",
    "test:parity": "npx tsx src/__tests__/parity.test.ts && npx tsx src/__tests__/parity.scenarios.test.ts"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "fast-glob": "^3.3.0",
    "js-yaml": "^4.1.0",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^25.8.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@google/adk": ">=0.2.0",
    "ai": ">=4.0.0",
    "claude-agent-sdk": ">=0.1.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "claude-agent-sdk": {
      "optional": true
    },
    "@google/adk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
