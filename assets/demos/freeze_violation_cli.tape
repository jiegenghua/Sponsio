# Freeze Violation — WITH Sponsio (real CLI / TerminalReporter output)
Output assets/demos/freeze_violation_cli.gif

Set FontSize 14
Set Width 1200
Set Height 1000
Set Padding 20
Set Theme "Dracula"
Set TypingSpeed 20ms

# Env must come AFTER Set — vhs 0.11 resets terminal dims otherwise.
Env PYTHONPATH "."

Type "sponsio demo --scenario freeze"
Enter
Sleep 11s
