# Sponsio API configuration
# Copy to .env and fill in values. Never commit .env to git.

# Required for --real mode in sponsio demo (LangGraph + Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: dashboard API URL (default: http://localhost:8000)
DASHBOARD_URL=http://localhost:8000

# Optional: CORS origins (comma-separated, default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
